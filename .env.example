# Anthropic API key — required
ANTHROPIC_API_KEY=sk-ant-...

# Model to use for commentary synthesis
# claude-sonnet-4-6  — default, faster and cheaper, great for standard/deep depth
# claude-opus-4-6    — maximum quality, use for critical sermon prep or eschatological passages
BIBLICAL_RESEARCH_MODEL=claude-sonnet-4-6

# Max tokens for commentary responses (default: 8096)
BIBLICAL_RESEARCH_MAX_TOKENS=8096

# File-based response cache (default: enabled)
# Set to "false" to always make fresh API calls
BIBLICAL_RESEARCH_CACHE=true

# Cache TTL in hours (default: 168 = 7 days)
# Commentary doesn't change, so a long TTL is fine
BIBLICAL_RESEARCH_CACHE_TTL_HOURS=168
